NODE_ENV=development
PORT=3001

MONGODB_URI=mongodb://localhost:27017/checkin_system

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=8h

QR_CHECKIN_SECRET=your-qr-checkin-secret-key
QR_CHECKIN_EXPIRES=300
QR_REGISTER_SECRET=your-qr-register-secret-key
QR_REGISTER_EXPIRES=3600

WEBAUTHN_RP_NAME=Office Checkin System
WEBAUTHN_RP_ID=checkin.office.local
WEBAUTHN_ORIGIN=https://checkin.office.local

ALLOWED_IP_RANGES=192.168.,10.,172.16.,172.17.,172.18.,172.19.,172.20.,172.21.,172.22.,172.23.,172.24.,172.25.,172.26.,172.27.,172.28.,172.29.,172.30.,172.31.,127.0.0.1,::1
